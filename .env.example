# Copy this file to .env and fill in real values for your machine.
# .env is gitignored — never commit real secrets.

# local | staging | production
NODE_ENV=local

PORT=3000

# Connection string for the app's own least-privilege database role
# (SELECT/INSERT/UPDATE/DELETE on app tables only — see scripts/db/01-create-app-role.sql).
# Never point this at the Postgres superuser/owner account.
DATABASE_URL=postgres://app_user:replace-with-app-user-password@localhost:5432/app_dev

# Connection string for the admin/owner role. Used only by drizzle-kit to
# generate/apply schema migrations — never read by the app's own runtime code.
MIGRATION_DATABASE_URL=postgres://postgres:replace-with-admin-password@localhost:5432/app_dev

# Symmetric secret used to sign access tokens (HS256) — 32+ random bytes, hex/base64 encoded
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_ISSUER=backend-service
JWT_AUDIENCE=backend-service-clients
# Access tokens are intentionally short-lived; refresh via the httpOnly cookie flow
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# debug | info | warn | error
LOG_LEVEL=debug

# Connection pool sizing so one slow query/spike can't exhaust the pool.
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_SECONDS=30
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=5000

# Number of reverse-proxy hops in front of this process (Express `trust
# proxy`). Get this wrong and rate limiting either becomes global (too low)
# or spoofable (too high). Verify by logging req.ip in your actual
# environment and confirming it's the real client IP, not the proxy's.
TRUST_PROXY_HOPS=1
BODY_SIZE_LIMIT=100kb
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# General limits on every request, checked independently by IP and (when
# authenticated) by account id.
RATE_LIMIT_GENERAL_IP_MAX=300
RATE_LIMIT_GENERAL_IP_WINDOW_MS=300000
RATE_LIMIT_GENERAL_ACCOUNT_MAX=600
RATE_LIMIT_GENERAL_ACCOUNT_WINDOW_MS=300000

# Stricter limits for login/register/password-reset, checked independently
# by IP and by the account/email being targeted.
RATE_LIMIT_AUTH_IP_MAX=20
RATE_LIMIT_AUTH_IP_WINDOW_MS=900000
RATE_LIMIT_AUTH_IDENTIFIER_MAX=5
RATE_LIMIT_AUTH_IDENTIFIER_WINDOW_MS=900000

# Tighter limit on the admin user-listing endpoint (the app's one currently
# expensive/unbounded-by-default endpoint).
RATE_LIMIT_ADMIN_LIST_MAX=30
RATE_LIMIT_ADMIN_LIST_WINDOW_MS=60000

# --- Required for staging and production only ---

# Allowed origin for CORS, e.g. https://staging.example.com
CORS_ORIGIN=

# Sentry project DSN (Settings -> Client Keys in Sentry dashboard)
SENTRY_DSN=

# --- Required for production only ---

# Stripe secret key — must start with sk_live_ in production
STRIPE_SECRET_KEY=
