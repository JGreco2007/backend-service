# Copy this file to .env and fill in real values for your machine.
# .env is gitignored — never commit real secrets.

# local | staging | production
NODE_ENV=local

PORT=3000

# Connection string for the app's own least-privilege database role
# (SELECT/INSERT/UPDATE/DELETE on app tables only — see scripts/db/create-app-user.sql).
# Never point this at the Postgres superuser/owner account.
DATABASE_URL=postgres://app_user:replace-with-app-user-password@localhost:5432/app_dev

# Connection string for the admin/owner role. Used only by drizzle-kit to
# generate/apply schema migrations — never read by the app's own runtime code.
MIGRATION_DATABASE_URL=postgres://postgres:replace-with-admin-password@localhost:5432/app_dev

# Symmetric secret used to sign auth tokens — 32+ random bytes, base64/hex encoded
JWT_SECRET=replace-with-a-long-random-string-min-16-chars

# debug | info | warn | error
LOG_LEVEL=debug

# Connection pool sizing so one slow query/spike can't exhaust the pool.
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_SECONDS=30
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_MS=5000

# --- Required for staging and production only ---

# Allowed origin for CORS, e.g. https://staging.example.com
CORS_ORIGIN=

# Sentry project DSN (Settings -> Client Keys in Sentry dashboard)
SENTRY_DSN=

# --- Required for production only ---

# Stripe secret key — must start with sk_live_ in production
STRIPE_SECRET_KEY=
